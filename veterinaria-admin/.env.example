# URL del backend API
# Para desarrollo local:
VITE_API_URL=http://localhost:3001/api/v1

# Para producción en Render (cambiar por tu nueva URL cuando la tengas):
# VITE_API_URL=https://tu-nueva-api.onrender.com/api/v1

# Nota: Después de cambiar estas variables, necesitas:
# 1. Reiniciar el servidor de desarrollo (npm run dev)
# 2. En producción (Netlify), configurar esto en las variables de entorno del sitio
