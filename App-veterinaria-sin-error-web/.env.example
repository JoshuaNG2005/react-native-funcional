# URL del backend API
# Para desarrollo local (web):
EXPO_PUBLIC_API_URL=http://localhost:3001

# Para desarrollo local (móvil en red local, cambiar IP por la tuya):
# EXPO_PUBLIC_API_URL=http://192.168.1.8:3001

# Para producción en Render (cambiar por tu nueva URL cuando la tengas):
# EXPO_PUBLIC_API_URL=https://tu-nueva-api.onrender.com

# Nota: Después de cambiar estas variables, necesitas:
# 1. Reiniciar Expo (Ctrl+C y luego npx expo start)
# 2. Para ver cambios en la app móvil, recargar la app (presiona 'r' en el terminal de Expo)
